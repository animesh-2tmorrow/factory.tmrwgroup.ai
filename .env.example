NODE_ENV=production
PORT=3000
NEXT_PUBLIC_SITE_URL=https://factory.tmrwgroup.ai
NEXT_PUBLIC_APP_URL=https://factory.tmrwgroup.ai
APP_URL=https://factory.tmrwgroup.ai
APP_ENV=staging

# Database (shared RDS, venture_factory schema)
DATABASE_URL=postgresql://tmrwadmin:PASSWORD@tmrwgroup-prod-db.cqlak8kka6cj.us-east-1.rds.amazonaws.com:5432/tmrwgroup_prod?schema=venture_factory

# NextAuth
NEXTAUTH_URL=https://factory.tmrwgroup.ai
NEXTAUTH_SECRET=GENERATE_WITH_openssl_rand_hex_32

# JWT + refresh auth (extension + API bearer support)
JWT_SECRET=GENERATE_WITH_openssl_rand_hex_32
JWT_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=12

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Team whitelist (comma-separated emails allowed to sign in)
ALLOWED_EMAILS=animesh@2tmorrow.com,edward@2tmorrow.com,ronnie@2tmorrow.com,zach@2tmorrow.com

# Stripe billing (required for live checkout)
STRIPE_SECRET_KEY=
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=

# ECS runtime provisioning for agents
AWS_REGION=us-east-1
ECS_CLUSTER_ARN=
ECS_TASK_DEFINITION_ARN=
ECS_SUBNET_IDS=subnet-aaa,subnet-bbb
ECS_SECURITY_GROUP_IDS=sg-aaa
AGENT_CONTAINER_NAME=agent
